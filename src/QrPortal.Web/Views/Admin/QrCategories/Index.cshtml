@model IEnumerable<QrPortal.Domain.Entities.QrCategory>
<h2 class="mb-3">Categorie QR</h2>
<div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Nome</th><th>Descrizione</th></tr></thead>
<tbody>@foreach(var c in Model){<tr><td>@c.Name</td><td>@c.Description</td></tr>}</tbody></table></div></div>
