@model IEnumerable<QrPortal.DataAccess.Interfaces.QrScanListItem>
<h2 class="mb-3">Scansioni QR</h2>
<div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table mb-0">
<thead><tr><th>Data</th><th>Cliente</th><th>QR</th><th>IP</th><th>Località</th></tr></thead>
<tbody>@foreach (var s in Model){<tr><td>@s.ScanDate:dd/MM/yyyy HH:mm</td><td>@s.ClientName</td><td>@s.QrTitle</td><td>@s.IpAddress</td><td>@s.City @s.Country</td></tr>}</tbody>
</table></div></div>
