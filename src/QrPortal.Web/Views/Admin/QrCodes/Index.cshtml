@model IEnumerable<QrPortal.DataAccess.Interfaces.QrCodeListItem>
<h2 class="mb-3">QR Code</h2>
<div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table mb-0">
<thead><tr><th>ID</th><th>Cliente</th><th>Titolo</th><th>Tipo</th><th>Scansioni</th><th>Stato</th></tr></thead>
<tbody>@foreach (var q in Model){<tr><td>@q.Id</td><td>@q.ClientName</td><td>@q.Title</td><td>@q.QrTypeName</td><td>@q.ScanCount</td><td>@q.Status</td></tr>}</tbody>
</table></div></div>
