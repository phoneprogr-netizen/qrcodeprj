@model IEnumerable<QrPortal.Domain.Entities.QrType>
<h2 class="mb-3">Tipologie QR</h2>
<div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Codice</th><th>Nome</th><th>Categoria</th><th>Dinamico</th></tr></thead>
<tbody>@foreach(var t in Model){<tr><td>@t.Code</td><td>@t.Name</td><td>@t.Category</td><td>@(t.IsDynamicSupported?"Sì":"No")</td></tr>}</tbody></table></div></div>
