<section class="page-banner">
    <h1 class="mb-3">Registrati</h1>
    <p class="lead mb-0">Compila i tuoi dati e richiedi una prova guidata di QR Portal Web.</p>
</section>

<div class="card feature-card">
    <div class="card-body p-4">
        <form class="row g-3 col-lg-10">
        <div class="col-md-6">
            <label class="form-label">Nome azienda</label>
            <input class="form-control" placeholder="La tua azienda" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Referente</label>
            <input class="form-control" placeholder="Nome e cognome" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Email</label>
            <input class="form-control" type="email" placeholder="nome@azienda.it" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Telefono</label>
            <input class="form-control" placeholder="+39" />
        </div>
        <div class="col-12">
            <button type="button" class="btn btn-primary">Invia richiesta</button>
            <a class="btn btn-link" asp-controller="Home" asp-action="Demo">Prima vuoi vedere la demo?</a>
        </div>
        </form>
    </div>
</div>
