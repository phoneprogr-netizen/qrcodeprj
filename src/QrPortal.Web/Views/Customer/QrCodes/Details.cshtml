@model QrPortal.Domain.Entities.QrCode

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-1">@Model.Title</h2>
        <p class="text-muted mb-0">Dettaglio QR e download file di stampa.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" href="@Url.Action("DownloadPng", new { id = Model.Id })">Scarica PNG</a>
        <a class="btn btn-outline-secondary" href="@Url.Action("DownloadSvg", new { id = Model.Id })">Scarica SVG</a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">ID</dt><dd class="col-sm-9">@Model.Id</dd>
            <dt class="col-sm-3">Tipo</dt><dd class="col-sm-9">@Model.QrTypeId</dd>
            <dt class="col-sm-3">Contenuto generato</dt><dd class="col-sm-9"><code>@Model.GeneratedContent</code></dd>
            <dt class="col-sm-3">Titolo</dt><dd class="col-sm-9">@Model.Title</dd>
        </dl>
    </div>
</div>
