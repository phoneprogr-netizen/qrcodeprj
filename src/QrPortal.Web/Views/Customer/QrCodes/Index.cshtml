@model QrPortal.Web.ViewModels.CustomerQrCodeIndexVm

<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h2 class="mb-1">I miei QR Code</h2></div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white"><strong>Crea nuovo QR</strong></div>
    <div class="card-body">
        <form asp-action="Create" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Create.ClientId" />
            <div class="col-md-4"><label class="form-label">Titolo</label><input asp-for="Create.Title" class="form-control" required /></div>
            <div class="col-md-3"><label class="form-label">Tipo QR</label><select asp-for="Create.QrTypeId" class="form-select">@foreach (var t in Model.Types){<option value="@t.Id">@t.Name</option>}</select></div>
            <div class="col-md-3"><label class="form-label">Categoria</label><select asp-for="Create.CategoryId" class="form-select"><option value="">-</option>@foreach (var c in Model.Categories){<option value="@c.Id">@c.Name</option>}</select></div>
            <div class="col-md-2"><label class="form-label">Dinamico</label><input asp-for="Create.IsDynamic" type="checkbox" class="form-check-input ms-2" /></div>
            <div class="col-12"><label class="form-label">URL destinazione</label><input asp-for="Create.DestinationUrl" class="form-control" placeholder="https://..." /></div>
            <div class="col-12"><label class="form-label">Payload JSON</label><textarea asp-for="Create.PayloadJson" class="form-control" rows="2"></textarea></div>
            <div class="col-12 d-flex justify-content-end"><button class="btn btn-primary" type="submit">Genera QR</button></div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead><tr><th>ID</th><th>Titolo</th><th>Tipo</th><th>Stato</th><th>Scansioni</th><th></th></tr></thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>#@item.Id</td><td>@item.Title</td><td>@item.QrTypeName</td><td>@item.Status</td><td>@item.ScanCount</td>
                        <td><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.Id">Apri</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
