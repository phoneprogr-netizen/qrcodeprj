<!doctype html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>QR Portal Web</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,500,0,0" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="public-site">
<nav class="navbar navbar-expand-lg navbar-dark top-nav">
    <div class="container">
        <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">QR Portal Web</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="About">Chi siamo</a></li>
                <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Contact">Contattaci</a></li>
                <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Register">Registrati</a></li>
                <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Demo">Demo</a></li>
            </ul>
            <div class="d-flex gap-2">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    if (User.IsInRole("Customer"))
                    {
                        <a class="btn btn-outline-light" asp-area="Customer" asp-controller="Dashboard" asp-action="Index">Dashboard Customer</a>
                    }
                    else
                    {
                        <a class="btn btn-outline-light" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard Admin</a>
                    }

                    <form method="post" asp-area="" asp-controller="Auth" asp-action="Logout">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-warning">Logout</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-outline-light" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Area Admin</a>
                    <a class="btn btn-success" asp-area="" asp-controller="Auth" asp-action="Login">Sei già cliente? Accedi</a>
                }
            </div>
        </div>
    </div>
</nav>
<main class="container py-4">@RenderBody()</main>
<footer class="site-footer mt-5">
    <div class="container py-4 d-flex flex-column flex-md-row justify-content-between gap-3">
        <div>
            <h5 class="mb-1">QR Portal Web</h5>
            <p class="mb-0 text-light-emphasis">Gestione QR professionale per aziende, agenzie e franchising.</p>
        </div>
        <div class="d-flex flex-wrap gap-3 align-items-center">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <a asp-controller="Home" asp-action="About">Chi siamo</a>
            <a asp-controller="Home" asp-action="Contact">Contattaci</a>
            <a asp-controller="Home" asp-action="Register">Registrati</a>
            <a asp-controller="Home" asp-action="Demo">Demo</a>
        </div>
    </div>
</footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
